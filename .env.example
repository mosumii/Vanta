# ═══════════════════════════════════════════════
# Vanta Socials — Environment Variables
# ═══════════════════════════════════════════════
#
# This file documents all external service credentials.
# Copy to .env and fill in your values.
#
# IMPORTANT: For a static site, these values go in different places:
#
# ── SAFE TO PUT IN js/config.js (public, by design) ──
# These are meant to be public-facing URLs:
FORMSPREE_URL=             # https://formspree.io/f/your-form-id
GOOGLE_SHEET_URL=          # https://script.google.com/macros/s/your-deployment/exec
STRIPE_TIER1_LINK=         # https://buy.stripe.com/your-link
STRIPE_TIER2_LINK=         # https://buy.stripe.com/your-link
STRIPE_TIER3_LINK=         # https://buy.stripe.com/your-link
CALENDLY_URL=              # https://calendly.com/your-name/strategy-call

# ── NEVER PUT IN BROWSER CODE (server-side only) ──
# These go in Google Apps Script ONLY:
TWILIO_ACCOUNT_SID=        # ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=          # your_auth_token (KEEP SECRET)
TWILIO_PHONE_FROM=         # +15551234567
TWILIO_PHONE_TO=           # +15559876543

# ── DOMAIN / HOSTING ──
DOMAIN=                    # vantasocials.com
VERCEL_TEAM=               # vantasocials
